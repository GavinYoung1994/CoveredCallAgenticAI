# ════════════════════════════════════════════════════════════════════
#  Covered Call Agentic AI — environment template
#  Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ════════════════════════════════════════════════════════════════════

# ── Charles Schwab Developer API ──────────────────────────────────────
SCHWAB_APP_KEY=your-schwab-app-key
SCHWAB_APP_SECRET=your-schwab-app-secret
SCHWAB_REDIRECT_URI=https://127.0.0.1

# ── massive.com news API ──────────────────────────────────────────────
MASSIVE_API_KEY=your-massive-api-key
MASSIVE_API_BASE_URL=https://api.massive.com
MASSIVE_NEWS_PATH=/v2/reference/news
MASSIVE_RATE_LIMIT_CALLS=5          # free tier: 5 requests...
MASSIVE_RATE_LIMIT_PERIOD_SEC=60    # ...per 60 seconds
# Optional: restrict news to specific sources (comma-separated, case-insensitive
# substring match on publisher name). Leave blank to accept all sources.
NEWS_ALLOWED_PUBLISHERS=
# Optional: block specific sources. Takes precedence over the allowlist.
NEWS_DISALLOWED_PUBLISHERS=

# ── Finnhub earnings calendar (free tier) ────────────────────────────
# Used by the News node's earnings guardrail. Without it, earnings is treated
# as UNKNOWN (flagged but allowed). Get a free key at finnhub.io.
FINNHUB_API_KEY=your-finnhub-api-key
EARNINGS_API_BASE_URL=https://finnhub.io/api/v1
EARNINGS_PATH=/calendar/earnings
# Fallback when Finnhub returns no date: scrape a Google search for the earnings
# date (best-effort; may be blocked). Finds the next date or infers it quarterly.
EARNINGS_SEARCH_ENABLED=true
EARNINGS_SEARCH_QUERY={ticker} stock next earnings date
# Use the local LLM to disambiguate WHICH extracted date is the earnings date
# (it may only pick from regex-grounded candidates → no hallucinated dates).
EARNINGS_SEARCH_USE_LLM=true

# ── Charles Schwab base URL (rarely changed) ─────────────────────────
SCHWAB_BASE_URL=https://api.schwabapi.com/marketdata/v1

# ── Discord HITL webhook ──────────────────────────────────────────────
# Create via: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# ── ChromaDB semantic memory ──────────────────────────────────────────
# Embedding backend: "auto" (prefer sentence-transformers if installed, else
# ChromaDB's built-in ONNX MiniLM — no torch needed), "sentence_transformers",
# or "default". Same MiniLM-L6-v2 model either way.
EMBEDDING_BACKEND=auto

# ── Local LLM ─────────────────────────────────────────────────────────
LLM_MODEL_PATH=model/qwen2.5-coder-14b-instruct-q4_k_m.gguf
LLM_CONTEXT_SIZE=50000
LLM_GPU_LAYERS=-1          # -1 = offload all layers to GPU (Metal); 0 = CPU only
LLM_TEMPERATURE=0.2        # low temp: we want consistent, conservative reasoning
